#!/bin/sh
# ----------------------------------------------------------------------------
# Maven Wrapper Startup Script
# ----------------------------------------------------------------------------

# OS specific support
set -e

# Get the directory of this script
DIR="$(cd "$(dirname "$0")" && pwd)"

# Use the Maven wrapper JAR
MAVEN_OPTS="$MAVEN_OPTS -XX:+TieredCompilation -XX:TieredStopAtLevel=1"

# Execute Maven
exec "$DIR/mvnw" "$@"